{
    "version": 3,
    "configurePresets": [
	{
		"name": "base",
		"hidden": true,
		"generator": "Ninja",
		"binaryDir": "${sourceDir}/cache",
		"cacheVariables": {
			"CMAKE_BUILD_TYPE": "Debug"
		}
	},
	{
		"name": "vcpkg-cl",
		"inherits": "base",
		"description": "Build, that uses vcpkg package manager with MSVC compiler",
		"cacheVariables": {
			"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
			"CMAKE_C_COMPILER": "cl",
			"CMAKE_CXX_COMPILER": "cl"
		},
		"condition": {
			"type": "equals",
			"lhs": "${hostSystemName}",
			"rhs": "Windows"
		}
	},
	{
		"name": "vcpkg-gcc",
		"inherits": "base",
		"description": "Build, that uses vcpkg package manager with GCC compiler",
		"cacheVariables": {
			"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
			"CMAKE_C_COMPILER": "gcc",
			"CMAKE_CXX_COMPILER": "g++"
		}
	},
	{
		"name": "vendor-gcc",
		"inherits": "base",
		"description": "Build, that uses gitmodule vendoring with GCC compiler",
		"cacheVariables": {
			"CMAKE_C_COMPILER": "gcc",
			"CMAKE_CXX_COMPILER": "g++"
		}
	},
	{
		"name": "vendor-clang",
		"inherits": "base",
		"description": "Build, that uses gitmodule vendoring with CLang compiler",
		"cacheVariables": {
			"CMAKE_C_COMPILER": "clang",
			"CMAKE_CXX_COMPILER": "clang++"
		}
	}
    ],
	"buildPresets": [
        {
            "name": "vnd-gcc",
            "displayName": "Vendored GCC",
            "configurePreset": "vendor-gcc"
        },
		{
            "name": "vcp-cl",
            "displayName": "Vcpkg CL",
            "configurePreset": "vcpkg-cl"
        },
		{
            "name": "vcp-gcc",
            "displayName": "Vcpkg GCC",
            "configurePreset": "vcpkg-gcc"
        },
		{
            "name": "vnd-clg",
            "displayName": "Vendored CLang",
            "configurePreset": "vendor-clang"
        }
	]
}
